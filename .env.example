# AWS Lambda Environment Variables
# Copy this file to .env and fill in the actual values

# Environment stage
STAGE=dev
AWS_REGION=us-east-1

# SFDC Configuration
tablename=ASF_Communication_Logs
envname=prod
sfdc_api_version=v62.0

# LOB API Configuration
hostname=api.lob.com
path=/v1/letters
api_key=your_lob_api_key_here

# SFDC API Configuration
crmpath=/services/data/v62.0/composite

# Attachment Configuration
loopLength=5

# Logging Configuration
isdebug=false

# Lambda Configuration
AWS_LAMBDA_MEMORY_IN_MB=512
AWS_LAMBDA_TIMEOUT=900

# Database Configuration (if using DynamoDB)
DYNAMODB_TABLE=communication-logs
DYNAMODB_REGION=us-east-1

# Secrets Manager
SFDC_AUTH_SECRET_NAME=prod_sfdc_auth